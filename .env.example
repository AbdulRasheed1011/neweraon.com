# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── HuggingFace Inference API ─────────────────────────────────────
# Get your free API key at: https://huggingface.co/settings/tokens
VITE_HF_API_KEY=hf_your_token_here

# HuggingFace model to use for the Home chat interface
# Free options: mistralai/Mistral-7B-Instruct-v0.2
#               HuggingFaceH4/zephyr-7b-beta
#               meta-llama/Meta-Llama-3-8B-Instruct
VITE_HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ── EmailJS (Contact Form) ─────────────────────────────────────────
# Set up free at: https://www.emailjs.com
# 1. Create account > Add email service (Gmail/Outlook)
# 2. Create email template > Copy Service ID and Template ID
# 3. Account > API Keys > Copy Public Key
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_EMAILJS_TO_EMAIL=your@email.com
